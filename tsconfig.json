{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*.ts", "dashboard/*.ts", "playwright.config.ts"]
}
